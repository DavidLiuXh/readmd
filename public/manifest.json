{
  "manifest_version": 3,
  "name": "MD Reader",
  "version": "1.0.0",
  "description": "Browse and read local Markdown files with directory tree",
  "action": {
    "default_icon": "icons/icon128.png",
    "default_title": "MD Reader"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": [],
  "icons": {
    "16": "icons/icon16.png",
    "128": "icons/icon128.png"
  }
}
