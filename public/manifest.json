{
  "manifest_version": 3,
  "name": "ReadMD",
  "version": "1.1.0",
  "description": "Browse and read local Markdown files beautifully — with directory tree, split view, dark mode and syntax highlighting.",
  "action": {
    "default_icon": "icons/icon128.png",
    "default_title": "ReadMD"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["file:///*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "tabs"],
  "host_permissions": ["file:///*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  }
}
