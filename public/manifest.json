{
  "manifest_version": 3,
  "name": "MD Reader",
  "version": "1.1.0",
  "description": "Browse and read local Markdown files with directory tree",
  "action": {
    "default_icon": "icons/icon128.png",
    "default_title": "MD Reader"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["file:///*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "tabs"],
  "host_permissions": ["file:///*"],
  "icons": {
    "16": "icons/icon16.png",
    "128": "icons/icon128.png"
  }
}
